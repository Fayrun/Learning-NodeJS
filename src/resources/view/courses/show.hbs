<div class="container-middle">
  <div class="show-hero">
  <div class="container-fluid px-4">
    <div class="show-hero-inner">

      <div class="show-poster">
        <!-- Nút theo dõi góc trên trái -->
        {{#if currentUser}}
          <button
            class="follow-btn {{#if isFollowing}}following{{/if}}"
            id="followBtn"
            onclick="toggleFollow('{{course._id}}')"
          >
            <i class="bi {{#if isFollowing}}bi-bookmark-heart-fill{{else}}bi-bookmark-heart{{/if}}"></i>
            <span>{{#if isFollowing}}Đã theo dõi{{else}}Theo dõi{{/if}}</span>
          </button>
        {{/if}}

        <img src="{{course.image}}" alt="{{course.name}}" />
        <a href="#course-video" class="show-watch-btn">XEM PHIM</a>
      </div>

      <div class="show-info">
        <h1 class="show-title">{{course.name}}</h1>
        <p class="show-desc">{{course.description}}</p>

        <div class="show-video-inline" id="course-video">
          <iframe
            src="https://www.youtube.com/embed/{{course.videoId}}"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen>
          </iframe>
        </div>

        <div class="show-rating-bar">
          <div class="show-rating-left">
            <div class="show-score">86%</div>
            <div class="show-stars">
              <span class="stars">★★★★★★★★★☆</span>
              <small>(72 luot, danh gia: 8.6 tren 10)</small>
            </div>
          </div>
          <div class="show-meta">
            <span><i class="bi bi-clock"></i> {{course.duration}} Phut</span>
            <span><i class="bi bi-calendar"></i> {{course.releaseYear}}</span>
            <span><i class="bi bi-eye"></i> 93,280 luot xem</span>
          </div>
        </div>

      </div>

    </div>
  </div>
</div>

<div class="container-fluid px-4 mt-4 mb-4">
  <div class="show-section-title">
    <i class="bi bi-file-text"></i> Thong tin phim
  </div>
  <div class="show-detail-grid">
    <div class="show-detail-item">
      <span class="show-detail-label"><i class="bi bi-circle-fill"></i> Trang thai:</span>
      <span class="show-detail-value">{{course.numberOfEpisodes}}/{{course.numberOfEpisodes}} Tap - {{course.status}}</span>
    </div>
    <div class="show-detail-item">
      <span class="show-detail-label"><i class="bi bi-circle-fill"></i> Thoi luong:</span>
      <span class="show-detail-value">{{course.duration}} Phut</span>
    </div>
    <div class="show-detail-item">
      <span class="show-detail-label"><i class="bi bi-circle-fill"></i> The loai:</span>
      <span class="show-detail-value show-genres">
        {{#each course.Genre}}
          <a href="/courses?genre={{this}}">{{this}}</a>{{#unless @last}}, {{/unless}}
        {{/each}}
      </span>
    </div>
    <div class="show-detail-item">
      <span class="show-detail-label"><i class="bi bi-circle-fill"></i> Do phan giai:</span>
      <span class="show-detail-value">HD</span>
    </div>
    <div class="show-detail-item">
      <span class="show-detail-label"><i class="bi bi-circle-fill"></i> Quoc gia:</span>
      <span class="show-detail-value">{{course.country}}</span>
    </div>
    <div class="show-detail-item">
      <span class="show-detail-label"><i class="bi bi-circle-fill"></i> Chu y:</span>
      <span class="show-detail-value {{#if (eq course.warning "R18+")}}show-warning-badge{{else}}show-none-badge{{/if}}">
        {{course.warning}}
      </span>
    </div>
    <div class="show-detail-item">
      <span class="show-detail-label"><i class="bi bi-circle-fill"></i> Nha san xuat:</span>
      <span class="show-detail-value">{{course.studio}}</span>
    </div>
    <div class="show-detail-item">
      <span class="show-detail-label"><i class="bi bi-circle-fill"></i> Tap moi:</span>
      <span class="show-detail-value">{{course.numberOfEpisodes}}</span>
    </div>
  </div>
</div>
</div>

<style>
  .follow-btn {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(10, 20, 40, 0.82);
    border: 1.5px solid #4a7a9b;
    color: #c0d8e8;
    border-radius: 20px;
    padding: 0.35rem 0.85rem;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    backdrop-filter: blur(4px);
  }

  .follow-btn:hover {
    border-color: #f0c040;
    color: #f0c040;
  }

  .follow-btn.following {
    background: rgba(106, 0, 255, 0.75);
    border-color: #7c3aed;
    color: #fff;
  }

  .follow-btn.following:hover {
    background: rgba(232, 0, 13, 0.75);
    border-color: #e8000d;
    color: #fff;
  }

  .follow-btn i { font-size: 0.95rem; }
</style>

<script>
async function toggleFollow(courseId) {
  const btn = document.getElementById("followBtn");
  const icon = btn.querySelector("i");
  const label = btn.querySelector("span");

  try {
    const res = await fetch(`/courses/${courseId}/follow`, { method: "POST" });
    const data = await res.json();

    if (data.following) {
      btn.classList.add("following");
      icon.className = "bi bi-bookmark-heart-fill";
      label.textContent = "Đã theo dõi";
    } else {
      btn.classList.remove("following");
      icon.className = "bi bi-bookmark-heart";
      label.textContent = "Theo dõi";
    }
  } catch (err) {
    console.error(err);
  }
}
</script>
