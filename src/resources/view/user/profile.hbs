<div class="container-middle">
  <div class="container-fluid px-4 mt-4">
    <div class="profile-wrapper">

      <!-- Sidebar -->
      <div class="profile-sidebar">
        <div class="profile-avatar-wrap">
          {{#if user.avatar}}
            <img src="{{user.avatar}}" class="profile-avatar" alt="avatar" />
          {{else}}
            <div class="profile-avatar-placeholder">
              <i class="bi bi-person-fill"></i>
            </div>
          {{/if}}
        </div>
        <p class="profile-username">{{user.username}}</p>
        <p class="profile-joined">THAM GIA: {{formatDate user.createdAt}}</p>
        <div class="profile-sidebar-links">
          <a href="/user/watchlist" class="profile-sidebar-link">
            <i class="bi bi-bookmark-heart-fill"></i> Hộp phim
          </a>
        </div>
      </div>

      <!-- Main Form -->
      <div class="profile-main">
        <h2 class="profile-title">THÔNG TIN TÀI KHOẢN</h2>

        {{#if error}}
          <div class="auth-error mb-3">
            <i class="bi bi-exclamation-circle-fill"></i> {{error}}
          </div>
        {{/if}}
        {{#if success}}
          <div class="auth-success mb-3">
            <i class="bi bi-check-circle-fill"></i> {{success}}
          </div>
        {{/if}}

        <form action="/user/profile" method="POST" enctype="multipart/form-data" class="profile-form">

          <div class="profile-field">
            <label>Email</label>
            <div class="profile-input-wrap">
              <i class="bi bi-envelope-fill"></i>
              <input type="email" value="{{user.email}}" disabled />
            </div>
          </div>

          <div class="profile-field">
            <label>Tài khoản</label>
            <div class="profile-input-wrap">
              <i class="bi bi-person-fill"></i>
              <input type="text" value="{{user.username}}" disabled />
            </div>
          </div>

          <div class="profile-field">
            <label>Họ tên</label>
            <div class="profile-input-wrap">
              <i class="bi bi-person-badge-fill"></i>
              <input type="text" name="fullName" value="{{user.fullName}}" placeholder="Họ và tên" />
            </div>
          </div>

          <div class="profile-field">
            <label>Giới tính</label>
            <div class="profile-gender">
              <label class="gender-option">
                <input type="radio" name="gender" value="male" {{#if (eq user.gender "male")}}checked{{/if}} />
                <span>Nam</span>
              </label>
              <label class="gender-option">
                <input type="radio" name="gender" value="female" {{#if (eq user.gender "female")}}checked{{/if}} />
                <span>Nữ</span>
              </label>
              <label class="gender-option">
                <input type="radio" name="gender" value="other" {{#if (eq user.gender "other")}}checked{{/if}} />
                <span>Không xác định</span>
              </label>
            </div>
          </div>

          <div class="profile-field">
            <label>Mật khẩu mới</label>
            <div class="profile-input-wrap">
              <i class="bi bi-lock-fill"></i>
              <input type="password" name="password" placeholder="Để trống nếu không muốn đổi" />
            </div>
          </div>

          <div class="profile-field">
            <label>Avatar</label>
            <div class="profile-input-wrap file-wrap">
              <input type="file" name="avatar" accept="image/*" />
            </div>
            <p class="profile-hint">(Ảnh nhỏ hơn 5MB)</p>
          </div>

          <button type="submit" class="profile-save-btn">
            <i class="bi bi-save-fill"></i> Lưu thay đổi
          </button>

        </form>
      </div>

    </div>
  </div>
</div>

<style>
  .profile-wrapper {
    display: flex;
    gap: 2rem;
    padding: 1.5rem 0 3rem;
    align-items: flex-start;
  }

  .profile-sidebar {
    width: 220px;
    flex-shrink: 0;
    background: #0e2233;
    border: 1px solid #1a3a4a;
    border-radius: 12px;
    padding: 1.5rem 1rem;
    text-align: center;
  }

  .profile-avatar-wrap { margin-bottom: 1rem; }

  .profile-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #f0c040;
  }

  .profile-avatar-placeholder {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: #1a3a4a;
    border: 3px solid #f0c040;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    font-size: 2.5rem;
    color: #4a7a9b;
  }

  .profile-username {
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 0.2rem;
  }

  .profile-joined {
    color: #f0c040;
    font-size: 0.78rem;
    font-weight: 600;
    margin-bottom: 1.2rem;
  }

  .profile-sidebar-links { border-top: 1px solid #1a3a4a; padding-top: 1rem; }

  .profile-sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #a0bfd0;
    text-decoration: none;
    font-size: 0.88rem;
    padding: 0.4rem 0.5rem;
    border-radius: 6px;
    transition: background 0.15s;
  }

  .profile-sidebar-link:hover { background: #1a3a4a; color: #fff; }

  .profile-main {
    flex: 1;
    background: #0e2233;
    border: 1px solid #1a3a4a;
    border-radius: 12px;
    padding: 2rem;
  }

  .profile-title {
    color: #fff;
    font-size: 1.4rem;
    font-weight: 900;
    letter-spacing: 1px;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #f0c040;
  }

  .auth-success {
    background: rgba(0, 200, 100, 0.12);
    border: 1px solid rgba(0, 200, 100, 0.4);
    color: #00c864;
    border-radius: 8px;
    padding: 0.6rem 1rem;
    font-size: 0.87rem;
  }

  .profile-field { margin-bottom: 1.2rem; }

  .profile-field > label {
    display: block;
    color: #a0bfd0;
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.4rem;
  }

  .profile-input-wrap { position: relative; }

  .profile-input-wrap i {
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    color: #4a7a9b;
    font-size: 0.9rem;
  }

  .profile-input-wrap input[type="text"],
  .profile-input-wrap input[type="email"],
  .profile-input-wrap input[type="password"] {
    width: 100%;
    background: #071825;
    border: 1px solid #1a3a4a;
    border-radius: 8px;
    padding: 0.65rem 0.9rem 0.65rem 2.4rem;
    color: #fff;
    font-size: 0.93rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .profile-input-wrap input:disabled { opacity: 0.5; cursor: not-allowed; }
  .profile-input-wrap input:not(:disabled):focus { border-color: #f0c040; }

  .file-wrap input[type="file"] {
    width: 100%;
    background: #071825;
    border: 1px solid #1a3a4a;
    border-radius: 8px;
    padding: 0.55rem 0.9rem;
    color: #a0bfd0;
    font-size: 0.88rem;
    outline: none;
  }

  .profile-hint { color: #4a7a9b; font-size: 0.78rem; margin-top: 0.3rem; margin-bottom: 0; }

  .profile-gender { display: flex; gap: 1.5rem; padding: 0.5rem 0; }

  .gender-option {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #c0d8e8;
    font-size: 0.9rem;
    cursor: pointer;
  }

  .gender-option input[type="radio"] { accent-color: #e8000d; }

  .profile-save-btn {
    background: #e8000d;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 0.7rem 2rem;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    margin-top: 0.5rem;
    transition: background 0.2s;
  }

  .profile-save-btn:hover { background: #c0000b; }
</style>
