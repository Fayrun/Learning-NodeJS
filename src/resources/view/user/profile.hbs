<div class="container-middle">
  <div class="container-fluid px-4 mt-4">
    <div class="profile-wrapper">

      <!-- Sidebar -->
      <div class="profile-sidebar">
        <div class="profile-avatar-wrap">
          {{#if user.avatar}}
            <img src="{{user.avatar}}" class="profile-avatar" alt="avatar" />
          {{else}}
            <div class="profile-avatar-placeholder">
              <i class="bi bi-person-fill"></i>
            </div>
          {{/if}}
        </div>
        <p class="profile-username">{{user.username}}</p>
        <p class="profile-joined">THAM GIA: {{formatDate user.createdAt}}</p>
        <div class="profile-sidebar-links">
          <a href="/user/watchlist" class="profile-sidebar-link">
            <i class="bi bi-bookmark-heart-fill"></i> Hộp phim
          </a>
        </div>
      </div>

      <!-- Main Form -->
      <div class="profile-main">
        <h2 class="profile-title">THÔNG TIN TÀI KHOẢN</h2>

        {{#if error}}
          <div class="auth-error mb-3">
            <i class="bi bi-exclamation-circle-fill"></i> {{error}}
          </div>
        {{/if}}
        {{#if success}}
          <div class="auth-success mb-3">
            <i class="bi bi-check-circle-fill"></i> {{success}}
          </div>
        {{/if}}

        <form action="/user/profile" method="POST" enctype="multipart/form-data" class="profile-form">

          <div class="profile-field">
            <label>Email</label>
            <div class="profile-input-wrap">
              <i class="bi bi-envelope-fill"></i>
              <input type="email" value="{{user.email}}" disabled />
            </div>
          </div>

          <div class="profile-field">
            <label>Tài khoản</label>
            <div class="profile-input-wrap">
              <i class="bi bi-person-fill"></i>
              <input type="text" value="{{user.username}}" disabled />
            </div>
          </div>

          <div class="profile-field">
            <label>Họ tên</label>
            <div class="profile-input-wrap">
              <i class="bi bi-person-badge-fill"></i>
              <input type="text" name="fullName" value="{{user.fullName}}" placeholder="Họ và tên" />
            </div>
          </div>

          <div class="profile-field">
            <label>Giới tính</label>
            <div class="profile-gender">
              <label class="gender-option">
                <input type="radio" name="gender" value="male" {{#if (eq user.gender "male")}}checked{{/if}} />
                <span>Nam</span>
              </label>
              <label class="gender-option">
                <input type="radio" name="gender" value="female" {{#if (eq user.gender "female")}}checked{{/if}} />
                <span>Nữ</span>
              </label>
              <label class="gender-option">
                <input type="radio" name="gender" value="other" {{#if (eq user.gender "other")}}checked{{/if}} />
                <span>Không xác định</span>
              </label>
            </div>
          </div>

          <div class="profile-field">
            <label>Mật khẩu mới</label>
            <div class="profile-input-wrap">
              <i class="bi bi-lock-fill"></i>
              <input type="password" name="password" placeholder="Để trống nếu không muốn đổi" />
            </div>
          </div>

          <div class="profile-field">
            <label>Avatar</label>
            <div class="profile-input-wrap file-wrap">
              <input type="file" name="avatar" accept="image/*" />
            </div>
            <p class="profile-hint">(Ảnh nhỏ hơn 5MB)</p>
          </div>

          <button type="submit" class="profile-save-btn">
            <i class="bi bi-save-fill"></i> Lưu thay đổi
          </button>

        </form>
      </div>

    </div>
  </div>
</div>

