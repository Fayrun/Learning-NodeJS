<div class="container-middle">
  <div class="container-fluid px-4 mt-4">
    <div class="profile-wrapper">

      <!-- Sidebar -->
      <div class="profile-sidebar">
        <div class="profile-avatar-wrap">
          {{#if currentUser.avatar}}
            <img
              src="{{currentUser.avatar}}"
              class="profile-avatar"
              alt="avatar"
            />
          {{else}}
            <div class="profile-avatar-placeholder">
              <i class="bi bi-person-fill"></i>
            </div>
          {{/if}}
        </div>
        <p class="profile-username">{{currentUser.username}}</p>
        <div class="profile-sidebar-links">
          <a href="/user/profile" class="profile-sidebar-link">
            <i class="bi bi-person-fill"></i>
            Thông tin tài khoản
          </a>
          <a href="/user/watchlist" class="profile-sidebar-link active">
            <i class="bi bi-bookmark-heart-fill"></i>
            Hộp phim
          </a>
        </div>
      </div>

      <!-- Main -->
      <div class="profile-main">
        <h2 class="profile-title">
          <i class="bi bi-bookmark-heart-fill" style="color:#e8000d;"></i>
          HỘP PHIM
          <span class="watchlist-count">{{courses.length}} anime</span>
        </h2>

        {{#if courses.length}}
          <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-3">
            {{#each courses}}
              <div class="col">
                <div class="anime-card">
                  <div class="anime-thumb">
                    <a href="/courses/{{this.slug}}">
                      <img src="{{this.image}}" alt="{{this.name}}" />
                    </a>
                    <div class="anime-badge-ep">TẬP<br /><strong
                      >{{this.numberOfEpisodes}}</strong></div>
                    <div class="anime-year-bar">{{this.releaseYear}}</div>
                    <!-- Nút bỏ theo dõi -->
                    <button
                      class="unfollow-btn"
                      title="Bỏ theo dõi"
                      onclick="unfollowAnime('{{this._id}}', this)"
                    >
                      <i class="bi bi-bookmark-x-fill"></i>
                    </button>
                  </div>
                  <div class="anime-info">
                    <p class="anime-title">{{this.name}}</p>
                    <div class="anime-genres">
                      {{#each this.Genre}}
                        <span class="anime-genre-badge">{{this}}</span>
                      {{/each}}
                    </div>
                  </div>
                </div>
              </div>
            {{/each}}
          </div>
        {{else}}
          <div class="watchlist-empty">
            <i class="bi bi-bookmark-x"></i>
            <p>Chưa có anime nào trong hộp phim</p>
            <a href="/courses" class="auth-nav-btn register">Khám phá anime</a>
          </div>
        {{/if}}
      </div>

    </div>
  </div>
</div>

<script>
  async function unfollowAnime(courseId, btn) { try { const res = await
  fetch(`/courses/${courseId}/follow`, { method: "POST" }); const data = await
  res.json(); if (!data.following) { btn.closest(".col").remove(); } } catch
  (err) { console.error(err); } }
</script>